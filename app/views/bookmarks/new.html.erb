<h1>Add bookmark to <%= @list.name %></h1>

<%= form_with model: [@list, @bookmark] do |f| %>

  <div class="mb-3">
    <%= f.label :movie %>
    <%= f.collection_select :movie_id,
        Movie.all,
        :id,
        :title,
        {},
        class: "form-select" %>
  </div>

  <div class="mb-3">
    <%= f.label :comment %>
    <%= f.text_field :comment, class: "form-control" %>
  </div>

  <%= f.submit "Create Bookmark", class: "btn btn-primary" %>

<% end %>

<%= link_to "Back",
    list_path(@list),
    class: "btn btn-secondary mt-2" %>
