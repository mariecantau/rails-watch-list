<div class="banner">
  <div class="container">
    <h1>Save any kind of movies</h1>
  </div>
</div>

<div class="container mt-4">

  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2>My Lists</h2>

    <%= link_to "Create a movie list", new_list_path, class: "btn btn-success" %>
  </div>

  <div class="row">
    <% @lists.each do |list| %>

      <div class="col-12 col-md-6 col-lg-4 mb-4">

        <%= link_to list_path(list), class: "text-decoration-none" do %>

          <div class="card-category">
            <%= list.name %>
          </div>

        <% end %>

      </div>

    <% end %>
  </div>

</div>
