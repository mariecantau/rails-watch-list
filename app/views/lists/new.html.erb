<div class="container">
  <h1>New List</h1>

  <%= form_with model: @list do |f| %>

    <div class="mb-3">
      <%= f.label :name, class: "form-label" %>
      <%= f.text_field :name, class: "form-control" %>
    </div>

    <%= f.submit "Create List", class: "btn btn-primary" %>

  <% end %>

  <%= link_to "Back", lists_path, class: "btn btn-secondary mt-2" %>

</div>
